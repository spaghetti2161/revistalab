# Base de datos (SQLite por defecto)
DATABASE_URL="file:./data/db.sqlite"

# Clave secreta para JWT (cambiar en producción)
JWT_SECRET="cambia-esto-por-una-clave-secreta-larga-y-aleatoria"

# URL del sitio
NEXT_PUBLIC_SITE_URL="https://revistalaboratorio.com.ar"

# Email (SMTP para enviar newsletters e invitaciones)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="tu-email@gmail.com"
SMTP_PASS="tu-contraseña-de-aplicacion"
EMAIL_FROM="Revista Laboratorio <noreply@revistalaboratorio.com.ar>"

# Nombre del sitio
NEXT_PUBLIC_SITE_NAME="Revista Laboratorio"
